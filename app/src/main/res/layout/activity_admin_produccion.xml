<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/adminProduccionRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/rb_surface"
    android:orientation="vertical"
    tools:context=".AdminProduccionActivity">

    <!-- Top header — mismo estilo que AdminActivity -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/rb_surface"
        android:elevation="4dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingTop="12dp"
        android:paddingEnd="16dp"
        android:paddingBottom="12dp">

        <!-- Botón de volver -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardBack"
            android:layout_width="44dp"
            android:layout_height="44dp"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/rb_green"
            app:strokeWidth="1dp">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="Volver"
                android:padding="10dp"
                android:src="@drawable/ic_arrow_back_24"
                app:tint="@color/rb_green" />
        </com.google.android.material.card.MaterialCardView>

        <ImageView
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginStart="12dp"
            android:adjustViewBounds="true"
            android:contentDescription="@string/logo_content_description"
            android:scaleType="fitCenter"
            android:src="@drawable/logo_rosa_betania" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:text="@string/client_brand_name"
            android:textColor="@color/rb_green_dark"
            android:textSize="18sp"
            android:textStyle="bold" />

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <!-- Badge de producción -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/rb_green_soft"
            app:cardCornerRadius="8dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/rb_green"
            app:strokeWidth="1dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="10dp"
                android:paddingVertical="5dp"
                android:text="Producción"
                android:textColor="@color/rb_green_dark"
                android:textSize="12sp"
                android:textStyle="bold" />
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

    <!-- Título de sección -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="20dp"
        android:paddingEnd="20dp"
        android:paddingBottom="4dp">

        <TextView
            android:id="@+id/tvProduccionTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Seguimiento de producción"
            android:textColor="@color/rb_text_primary"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvProduccionSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:lineSpacingExtra="2dp"
            android:text="Gestione el avance de los pedidos confirmados por los clientes."
            android:textColor="@color/rb_text_secondary"
            android:textSize="14sp" />

    </LinearLayout>

    <!-- Tabs de filtro -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabsProduccion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:layout_marginHorizontal="16dp"
        android:background="@color/rb_grey_bg"
        app:tabBackground="@null"
        app:tabGravity="fill"
        app:tabIndicatorColor="@color/rb_green_dark"
        app:tabIndicatorFullWidth="false"
        app:tabIndicatorHeight="3dp"
        app:tabMode="fixed"
        app:tabRippleColor="@null"
        app:tabSelectedTextColor="@color/rb_green_dark"
        app:tabTextColor="@color/rb_text_secondary"
        app:tabTextAppearance="@style/TextAppearance.Material3.LabelLarge" />

    <!-- Divisor -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="4dp"
        android:background="@color/rb_divider" />

    <!-- Lista de pedidos en producción -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvProduccion"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingTop="8dp"
        android:paddingBottom="80dp" />

</LinearLayout>
