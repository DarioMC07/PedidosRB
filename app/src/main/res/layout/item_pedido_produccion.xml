<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="6dp"
    app:cardBackgroundColor="@color/white"
    app:cardCornerRadius="12dp"
    app:cardElevation="3dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Franja lateral de acento — color varía según estado (se aplica en código) -->
        <View
            android:id="@+id/stripeProduccion"
            android:layout_width="5dp"
            android:layout_height="0dp"
            android:background="@color/rb_green_dark"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="14dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/stripeProduccion"
            app:layout_constraintTop_toTopOf="parent">

            <!-- Fila: Nombre del trabajo + Chip de estado -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvProdNombre"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="@color/rb_text_primary"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    tools:text="Catálogo otoño 2024" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipProdEstado"
                    style="@style/Widget.Material3.Chip.Assist"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:textColor="@color/white"
                    android:textSize="11sp"
                    app:chipCornerRadius="8dp"
                    app:chipMinHeight="28dp"
                    tools:text="Pendiente" />
            </LinearLayout>

            <!-- Email del cliente con icono -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_person_24"
                    app:tint="@color/rb_text_secondary" />

                <TextView
                    android:id="@+id/tvProdCliente"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:textColor="@color/rb_text_secondary"
                    android:textSize="13sp"
                    tools:text="cliente@correo.com" />
            </LinearLayout>

            <!-- Divisor suave -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="10dp"
                android:background="@color/rb_divider" />

            <!-- Detalles del pedido -->
            <TextView
                android:id="@+id/tvProdDetalles"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:textColor="@color/rb_text_secondary"
                android:textSize="13sp"
                tools:text="100 unid. | Flyer | 21×15 cm | Couché" />

            <!-- Fila: precio + botón de acción -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvProdPrecio"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="@color/rb_green_dark"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    tools:text="Precio: $25.00" />

                <!-- Botón de cambiar estado (visible solo si no es Terminado) -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCambiarEstado"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="Cambiar estado"
                    android:textAllCaps="false"
                    android:textSize="12sp"
                    app:cornerRadius="8dp"
                    app:strokeColor="@color/rb_green"
                    android:textColor="@color/rb_green_dark" />
            </LinearLayout>

            <!-- Imagen del diseño (visible solo si existe) -->
            <ImageView
                android:id="@+id/ivProdImagen"
                android:layout_width="match_parent"
                android:layout_height="160dp"
                android:layout_marginTop="10dp"
                android:contentDescription="Imagen del diseño"
                android:scaleType="centerCrop"
                android:visibility="gone" />

        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>
