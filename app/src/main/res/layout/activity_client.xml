<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/clientRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/rb_surface"
    android:orientation="vertical"
    tools:context=".ClientActivity">

    <!-- Top header (white, brand left — profile right) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/rb_surface"
        android:elevation="4dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingTop="12dp"
        android:paddingEnd="16dp"
        android:paddingBottom="12dp">

        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:adjustViewBounds="true"
            android:contentDescription="@string/logo_content_description"
            android:scaleType="fitCenter"
            android:src="@drawable/logo_rosa_betania" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:text="@string/client_brand_name"
            android:textColor="@color/rb_green_dark"
            android:textSize="18sp"
            android:textStyle="bold" />

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardProfile"
            android:layout_width="44dp"
            android:layout_height="44dp"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/rb_green"
            app:strokeWidth="1dp">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="@string/client_profile_content_description"
                android:padding="10dp"
                android:src="@drawable/ic_person_24"
                app:tint="@color/rb_green" />
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingTop="20dp"
            android:paddingEnd="20dp"
            android:paddingBottom="24dp">

            <TextView
                android:id="@+id/tvPageTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/client_configure_title"
                android:textColor="@color/rb_text_primary"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvPageSubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:lineSpacingExtra="2dp"
                android:text="@string/client_configure_subtitle"
                android:textColor="@color/rb_text_secondary"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvSessionEmail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textColor="@color/rb_text_secondary"
                android:textSize="12sp"
                tools:text="usuario@correo.com" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="12dp"
                app:cardElevation="3dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <View
                        android:id="@+id/stripeAccent"
                        android:layout_width="6dp"
                        android:layout_height="0dp"
                        android:background="@color/rb_green_dark"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <LinearLayout
                        android:id="@+id/formContainer"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="18dp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@id/stripeAccent"
                        app:layout_constraintTop_toTopOf="parent">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:letterSpacing="0.08"
                            android:text="@string/client_job_name_label"
                            android:textAllCaps="true"
                            android:textColor="@color/rb_text_secondary"
                            android:textSize="11sp" />

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilJobName"
                            style="@style/Widget.Material3.TextInputLayout.FilledBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:hint="@string/client_job_name_hint"
                            app:boxBackgroundColor="@color/rb_grey_bg"
                            app:boxCornerRadiusBottomEnd="10dp"
                            app:boxCornerRadiusBottomStart="10dp"
                            app:boxCornerRadiusTopEnd="10dp"
                            app:boxCornerRadiusTopStart="10dp"
                            app:hintTextColor="@color/rb_hint_black">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etJobName"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="textCapSentences"
                                android:maxLines="1"
                                android:textColor="@color/rb_text_primary"
                                android:textColorHint="@color/rb_hint_black" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:letterSpacing="0.08"
                            android:text="@string/client_job_type_label"
                            android:textAllCaps="true"
                            android:textColor="@color/rb_text_secondary"
                            android:textSize="11sp" />

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilJobType"
                            style="@style/Widget.Material3.TextInputLayout.FilledBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            app:boxBackgroundColor="@color/rb_grey_bg"
                            app:boxCornerRadiusBottomEnd="10dp"
                            app:boxCornerRadiusBottomStart="10dp"
                            app:boxCornerRadiusTopEnd="10dp"
                            app:boxCornerRadiusTopStart="10dp"
                            app:hintTextColor="@color/rb_hint_black"
                            app:placeholderText="@string/client_job_type_hint"
                            app:endIconMode="dropdown_menu">

                            <com.google.android.material.textfield.MaterialAutoCompleteTextView
                                android:id="@+id/actJobType"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="none"
                                android:importantForAutofill="no"
                                android:textColor="@color/rb_text_primary"
                                android:textColorHint="@color/rb_hint_black"
                                android:singleLine="true" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:letterSpacing="0.08"
                            android:text="@string/client_quantity_label"
                            android:textAllCaps="true"
                            android:textColor="@color/rb_text_secondary"
                            android:textSize="11sp" />

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilQuantity"
                            style="@style/Widget.Material3.TextInputLayout.FilledBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            app:boxBackgroundColor="@color/rb_grey_bg"
                            app:boxCornerRadiusBottomEnd="10dp"
                            app:boxCornerRadiusBottomStart="10dp"
                            app:boxCornerRadiusTopEnd="10dp"
                            app:boxCornerRadiusTopStart="10dp"
                            app:hintTextColor="@color/rb_hint_black"
                            app:suffixText="Uds">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etQuantity"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="number"
                                android:maxLines="1"
                                android:textColor="@color/rb_text_primary"
                                android:textColorHint="@color/rb_hint_black"
                                android:text="100" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:letterSpacing="0.08"
                            android:text="@string/client_measures_label"
                            android:textAllCaps="true"
                            android:textColor="@color/rb_text_secondary"
                            android:textSize="11sp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:orientation="horizontal">

                            <com.google.android.material.textfield.TextInputLayout
                                android:id="@+id/tilLength"
                                style="@style/Widget.Material3.TextInputLayout.FilledBox"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:hint="@string/client_length_label"
                                app:boxBackgroundColor="@color/rb_grey_bg"
                                app:boxCornerRadiusBottomEnd="10dp"
                                app:boxCornerRadiusBottomStart="10dp"
                                app:boxCornerRadiusTopEnd="10dp"
                                app:boxCornerRadiusTopStart="10dp"
                                app:hintTextColor="@color/rb_hint_black"
                                app:suffixText="cm">

                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/etLength"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:inputType="numberDecimal"
                                    android:maxLines="1"
                                    android:textColor="@color/rb_text_primary"
                                    android:textColorHint="@color/rb_hint_black" />
                            </com.google.android.material.textfield.TextInputLayout>

                            <View
                                android:layout_width="12dp"
                                android:layout_height="1dp" />

                            <com.google.android.material.textfield.TextInputLayout
                                android:id="@+id/tilWidth"
                                style="@style/Widget.Material3.TextInputLayout.FilledBox"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:hint="@string/client_width_label"
                                app:boxBackgroundColor="@color/rb_grey_bg"
                                app:boxCornerRadiusBottomEnd="10dp"
                                app:boxCornerRadiusBottomStart="10dp"
                                app:boxCornerRadiusTopEnd="10dp"
                                app:boxCornerRadiusTopStart="10dp"
                                app:hintTextColor="@color/rb_hint_black"
                                app:suffixText="cm">

                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/etWidth"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:inputType="numberDecimal"
                                    android:maxLines="1"
                                    android:textColor="@color/rb_text_primary"
                                    android:textColorHint="@color/rb_hint_black" />
                            </com.google.android.material.textfield.TextInputLayout>
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:letterSpacing="0.08"
                            android:text="@string/client_observation_label"
                            android:textAllCaps="true"
                            android:textColor="@color/rb_text_secondary"
                            android:textSize="11sp" />

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilObservation"
                            style="@style/Widget.Material3.TextInputLayout.FilledBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:hint="@string/client_observation_hint"
                            app:boxBackgroundColor="@color/rb_grey_bg"
                            app:boxCornerRadiusBottomEnd="10dp"
                            app:boxCornerRadiusBottomStart="10dp"
                            app:boxCornerRadiusTopEnd="10dp"
                            app:boxCornerRadiusTopStart="10dp"
                            app:hintTextColor="@color/rb_hint_black">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etObservation"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="textCapSentences|textMultiLine"
                                android:minLines="2"
                                android:maxLines="4"
                                android:textColor="@color/rb_text_primary"
                                android:textColorHint="@color/rb_hint_black" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:letterSpacing="0.08"
                            android:text="@string/client_material_label"
                            android:textAllCaps="true"
                            android:textColor="@color/rb_text_secondary"
                            android:textSize="11sp" />

                        <com.google.android.material.chip.ChipGroup
                            android:id="@+id/chipGroupMaterial"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            app:selectionRequired="true"
                            app:singleSelection="true">

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chipCouche"
                                style="@style/Widget.Material3.Chip.Filter"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:checked="true"
                                android:text="@string/client_material_couche" />

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chipBond"
                                style="@style/Widget.Material3.Chip.Filter"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/client_material_bond" />

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chipCartulina"
                                style="@style/Widget.Material3.Chip.Filter"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/client_material_cartulina" />
                        </com.google.android.material.chip.ChipGroup>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:letterSpacing="0.08"
                            android:text="@string/client_gramaje_label"
                            android:textAllCaps="true"
                            android:textColor="@color/rb_text_secondary"
                            android:textSize="11sp" />

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilGramaje"
                            style="@style/Widget.Material3.TextInputLayout.FilledBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            app:boxBackgroundColor="@color/rb_grey_bg"
                            app:boxCornerRadiusBottomEnd="10dp"
                            app:boxCornerRadiusBottomStart="10dp"
                            app:boxCornerRadiusTopEnd="10dp"
                            app:boxCornerRadiusTopStart="10dp"
                            app:endIconMode="dropdown_menu"
                            app:hintTextColor="@color/rb_hint_black"
                            app:placeholderText="@string/client_gramaje_placeholder">

                            <com.google.android.material.textfield.MaterialAutoCompleteTextView
                                android:id="@+id/actGramaje"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:importantForAutofill="no"
                                android:inputType="none"
                                android:singleLine="true"
                                android:textColor="@color/rb_text_primary"
                                android:textColorHint="@color/rb_hint_black" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginTop="16dp"
                            android:background="@color/rb_divider" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:contentDescription="@null"
                                android:src="@drawable/ic_info_outline_24"
                                app:tint="@color/rb_text_secondary" />

                            <TextView
                                android:id="@+id/tvDeliveryInfo"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:layout_weight="1"
                                android:text="@string/client_delivery_info"
                                android:textColor="@color/rb_text_secondary"
                                android:textSize="13sp" />
                        </LinearLayout>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnSolicitar"
                            android:layout_width="match_parent"
                            android:layout_height="54dp"
                            android:layout_marginTop="18dp"
                            android:text="@string/client_submit"
                            android:textAllCaps="false"
                            android:textColor="@color/rb_on_green"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            app:backgroundTint="@color/rb_green"
                            app:cornerRadius="12dp" />
                    </LinearLayout>
                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
