<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="6dp"
    app:cardBackgroundColor="@color/white"
    app:cardCornerRadius="12dp"
    app:cardElevation="3dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Franja lateral de acento verde (igual que el formulario del cliente) -->
        <View
            android:id="@+id/stripeAccentItem"
            android:layout_width="5dp"
            android:layout_height="0dp"
            android:background="@color/rb_green_dark"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="14dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/stripeAccentItem"
            app:layout_constraintTop_toTopOf="parent">

            <!-- Fila: Nombre del trabajo + Chip de estado -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvNombreTrabajo"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="@color/rb_text_primary"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    tools:text="Catálogo otoño 2024"
                    xmlns:tools="http://schemas.android.com/tools" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipEstado"
                    style="@style/Widget.Material3.Chip.Assist"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:textColor="@color/white"
                    android:textSize="11sp"
                    app:chipCornerRadius="8dp"
                    app:chipMinHeight="28dp"
                    tools:text="Pendiente"
                    xmlns:tools="http://schemas.android.com/tools" />
            </LinearLayout>

            <!-- Email del cliente -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_person_24"
                    app:tint="@color/rb_text_secondary" />

                <TextView
                    android:id="@+id/tvCliente"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:textColor="@color/rb_text_secondary"
                    android:textSize="13sp"
                    tools:text="cliente@correo.com"
                    xmlns:tools="http://schemas.android.com/tools" />
            </LinearLayout>

            <!-- Divisor suave -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="10dp"
                android:background="@color/rb_divider" />

            <!-- Detalles del pedido -->
            <TextView
                android:id="@+id/tvDetalles"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:textColor="@color/rb_text_secondary"
                android:textSize="13sp"
                tools:text="100 unid. | Flyer | 21×15 cm | Couché"
                xmlns:tools="http://schemas.android.com/tools" />

            <!-- Precio -->
            <TextView
                android:id="@+id/tvPrecio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textColor="@color/rb_green_dark"
                android:textSize="14sp"
                android:textStyle="bold"
                tools:text="Precio: $25.00"
                xmlns:tools="http://schemas.android.com/tools" />

        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>
